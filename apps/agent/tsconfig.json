{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "paths": {
      "@sparkle/shared/*": ["./../../packages/shared/src/*"],
      "@sparkle/agent-runtime": ["./../../packages/agent-runtime/src/index.ts"],
      "@sparkle/llm": ["./../../packages/llm/src/index.ts"],
      "@sparkle/logger": ["./../../packages/logger/src/index.ts"],
      "@sparkle/config": ["./../../packages/config/src/index.ts"],
      "@sparkle/server-http": ["./../../packages/server-http/src/index.ts"],
      "@sparkle/llm-client": ["./../../packages/llm-client/src/index.ts"],
      "@sparkle/claude-code": ["./../../packages/claude-code/src/index.ts"],
      "@sparkle/db": ["./../../packages/db/src/index.ts"]
    }
  },
  "include": ["src"]
}
