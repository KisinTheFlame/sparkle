{
  "name": "@sparkle/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json && cp src/agent/system-prompt/main-system-prompt.hbs dist/agent/system-prompt/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sparkle/agent-runtime": "workspace:*",
    "@sparkle/claude-code": "workspace:*",
    "@sparkle/config": "workspace:*",
    "@sparkle/db": "workspace:*",
    "@sparkle/llm": "workspace:*",
    "@sparkle/llm-client": "workspace:*",
    "@sparkle/logger": "workspace:*",
    "@sparkle/server-http": "workspace:*",
    "@sparkle/shared": "workspace:*",
    "fastify": "^5.6.2",
    "handlebars": "^4.7.8",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
