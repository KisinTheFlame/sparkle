{
  "name": "@sparkle/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "db:generate": "DATABASE_URL=\"file:./.generate-placeholder.db\" prisma generate",
    "db:migrate:dev": "DATABASE_URL=\"${DATABASE_URL:-file:./dev.db}\" prisma migrate dev",
    "db:migrate:deploy": "DATABASE_URL=\"${DATABASE_URL:-file:./dev.db}\" prisma migrate deploy",
    "db:migrate:status": "DATABASE_URL=\"${DATABASE_URL:-file:./dev.db}\" prisma migrate status",
    "db:migrate:reset": "DATABASE_URL=\"${DATABASE_URL:-file:./dev.db}\" prisma migrate reset",
    "build": "pnpm db:generate && tsc -p tsconfig.build.json",
    "typecheck": "pnpm db:generate && tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "@sparkle/claude-code": "workspace:*",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "prisma": "^7.6.0",
    "typescript": "^5.9.3"
  }
}
