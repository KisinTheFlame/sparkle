{
  "name": "@sparkle/persistence",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./prisma": {
      "types": "./dist/generated/prisma/internal/prismaNamespace.d.ts",
      "default": "./dist/generated/prisma/internal/prismaNamespace.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.build.json",
    "typecheck": "pnpm db:generate && tsc --noEmit",
    "db:generate": "bash ../../scripts/prisma.sh generate",
    "test": "vitest run"
  },
  "dependencies": {
    "@sparkle/http": "workspace:*",
    "@sparkle/kernel": "workspace:*",
    "@sparkle/llm": "workspace:*",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "better-sqlite3": "^12.11.1",
    "prisma": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
