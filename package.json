{
  "name": "sparkle",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "build": "pnpm -r build",
    "app:deploy": "bash ./scripts/deploy.sh",
    "app:stop": "bash ./scripts/stop.sh",
    "db:migrate:dev": "bash ./scripts/prisma.sh migrate dev",
    "db:migrate:deploy": "bash ./scripts/prisma.sh migrate deploy",
    "db:migrate:status": "bash ./scripts/prisma.sh migrate status",
    "db:migrate:reset": "bash ./scripts/prisma.sh migrate reset",
    "db:migrate:resolve": "bash ./scripts/prisma.sh migrate resolve",
    "typecheck": "pnpm -r typecheck",
    "test": "NODE_OPTIONS=--max-old-space-size=2048 vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "knip": "DATABASE_URL=file:./.knip-db-placeholder knip"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@sparkle/config": "workspace:*",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "knip": "^6.24.0",
    "pm2": "^6.0.14",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^3.2.4",
    "yaml": "^2.8.2"
  }
}
