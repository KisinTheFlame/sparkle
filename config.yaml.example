# 复制为 config.yaml 后按需修改。config.yaml 已被 .gitignore 忽略。

# 服务寻址单源：各进程的监听端口取自自己的条目（一律绑 0.0.0.0），
# 别的服务/前端按 host:port 反查上游。ecosystem.config.cjs 不再持任何端口。
# host 是「如何 reach 它」（reachable host），不是绑定地址。
services:
  agent: { host: localhost, port: 20003 } # sparkle-agent（LLM / OAuth 后端）
  console: { host: localhost, port: 20006 } # sparkle-console（管理台后端）
  web: { host: localhost, port: 4173 } # sparkle-web（前门：vite preview 静态托管 + 反代）

server:
  # SQLite 库地址；相对路径按 config.yaml 所在目录解析为绝对 file: URL。
  # 与 @sparkle/db 的迁移共用同一库文件（迁移时 DATABASE_URL 指向同一路径）。
  databaseUrl: "file:./data/sparkle.db"

  llm:
    # 单次 LLM 请求超时
    timeoutMs: 45000

    # Claude Code OAuth 登录配置
    claudeCodeAuth:
      enabled: true
      # 对外可访问的基址；缺省派生为 http://localhost:${services.web.port}，可显式覆盖。
      # publicBaseUrl: "http://localhost:4173"
      oauthRedirectPath: "/callback"
      oauthStateTtlMs: 600000
      refreshLeewayMs: 7200000
      refreshCheckIntervalMs: 300000

    providers:
      claudeCode:
        baseUrl: "https://api.anthropic.com"
        models:
          - "claude-sonnet-4-20250514"
        keepAliveReplayIntervalMinutes: 30

    # 各用途的多 attempt 路由：按顺序尝试，每个 attempt 可重试 times 次。
    usages:
      agent:
        attempts:
          - provider: "claude-code"
            model: "claude-sonnet-4-20250514"
            times: 1

  # 各 App 的配置切片（key 为 App.id），由各 App 自己的 schema 校验。
  apps: {}
